[Desktop Entry]
Actions=agif;append-right;_SEPARATOR_;gray;sepia;transparent2color;_SEPARATOR_;border;border-transparent;shadow;_SEPARATOR_;
MimeType=image/*
Name=ReImage tools service menu
ServiceTypes=KonqPopupMenu/Plugin,image/*
TryExec=reimage-kdialog
Type=Service
X-KDE-Submenu=ReImage - Tools
X-KDE-Submenu[ar]=ReImage - أدوات
X-KDE-Submenu[it]=ReImage - Utilità
X-KDE-Submenu[ja]=ReImage - ツール
X-KDE-Submenu[de]=ReImage - Utilitäten
X-KDE-Submenu[eo]=ReImage - Iloj
X-KDE-Submenu[fr]=ReImage - Outils
X-KDE-Submenu[es]=ReImage - Herramientas
X-KDE-Submenu[pt]=ReImage - Ferramentas
X-KDE-Submenu[fa]=ReImage - ابزارها
X-KDE-Submenu[zh_CN]=ReImage - 工具
X-KDE-Submenu[ru]=ReImage - Инструменты

################################################################################

[Desktop Action agif]
Exec=reimage-kdialog agif %F
Icon=video-x-mp4
Name=Create animated GIF
Name[ar]=إنشاء GIF متحرك
Name[it]=Crea GIF animata
Name[ja]=アニメーション GIF を作成
Name[de]=Animierte GIF erstellen
Name[eo]=Krei animacian GIF
Name[fr]=Créer un GIF animé
Name[es]=Crear GIF animado
Name[pt]=Criar GIF animado
Name[fa]=تولید GIF متحرک
Name[zh_CN]=生成动画 GIF
Name[ru]=Создать анимированный GIF

[Desktop Action append-right]
Exec=reimage-kdialog montage %F
Icon=image-stack
Name=Append to right
Name[ar]=إلحاق إلى اليمين
Name[it]=Appendi immagine a destra
Name[ja]=右側に結合
Name[de]=Nach rechts anhängen
Name[eo]=Postglui dekstren
Name[fr]=Ajouter à droite
Name[es]=Añadir a la derecha
Name[pt]=Anexar à direita
Name[fa]=پیوست به راست
Name[zh_CN]=右侧追加
Name[ru]=Прикрепить справа

################################################################################

[Desktop Action gray]
Exec=reimage-kdialog colorspace gray %F
Icon=color-management
Name=GrayScale
Name[ar]=تدرج الرمادي
Name[it]=Scala di grigi
Name[ja]=グレースケール
Name[de]=Graustufen
Name[eo]=Grizoskalo
Name[fr]=Niveaux de gris
Name[es]=Escala de grises
Name[pt]=Escala de cinzentos
Name[fa]=سیاه و سفید
Name[zh_CN]=灰度
Name[ru]=Оттенки серого

[Desktop Action sepia]
Exec=reimage-kdialog sepia 80% %F
Icon=color-management
Name=Sepia
Name[ar]=سيبيا
Name[it]=Seppia
Name[ja]=セピア
Name[de]=Sepia
Name[eo]=Sepia
Name[fr]=Sépia
Name[es]=Sepia
Name[pt]=Sépia
Name[fa]=سپیا
Name[zh_CN]=棕褐色
Name[ru]=Сепия

[Desktop Action transparent2color]
Exec=reimage-kdialog transparent2color %F
Icon=color-management
Name=Change transparent to color
Name[ar]=تغيير الشفافية إلى لون
Name[it]=Cambia trasparenza a colore
Name[ja]=透明部分を色に変更
Name[de]=Transparenz in Farbe ändern
Name[eo]=Ŝanĝi travideblecon al koloro
Name[fr]=Changer la transparence en couleur
