Name[pt]=Adicionar borda colorida
Name[fa]=افزودن حاشیه رنگی
Name[zh_CN]=添加彩色边框
Name[ru]=Добавить цветную рамку

[Desktop Action border-transparent]
Exec=reimage-kdialog border transparent %F
Icon=border-all
Name=Add transparent border
Name[ar]=إضافة إطار شفاف
Name[it]=Aggiungi bordo trasparente
